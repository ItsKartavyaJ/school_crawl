# ── Gemini API ────────────────────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

LANGEXTRACT_MODEL=gemini-2.5-flash
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# Only needed if EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=

# ── Qdrant Cloud ──────────────────────────────────────────────────────────────
# 1. Go to https://cloud.qdrant.io → create a free cluster
# 2. Copy the cluster URL (https://xxxx.us-east4-0.gcp.cloud.qdrant.io)
# 3. Generate an API key from the cluster dashboard
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=school_intel
QDRANT_RAW_COLLECTION=school_intel_raw

# ── Spider ────────────────────────────────────────────────────────────────────
# "auto" = detect per-site, "true" = always JS, "false" = never JS
USE_JS_RENDERING=auto
RESPECT_ROBOTS_TXT=false
MAX_PAGES_PER_SCHOOL=250
CONCURRENT_REQUESTS=5
DOWNLOAD_DELAY=1.0
PDF_BUDGET_RATIO=0.5
DOWNLOAD_ALL_PDFS=true
ALLOWED_EXTERNAL_PDF_HOSTS=resources.finalsite.net

# ── Text extraction thresholds ────────────────────────────────────────────────
MIN_PAGE_TEXT_LENGTH=200
MIN_PDF_TEXT_LENGTH=50

# ── Retry settings ────────────────────────────────────────────────────────────
RETRY_ATTEMPTS=3
RETRY_WAIT_MIN=1.0
RETRY_WAIT_MAX=10.0

# ── Raw text truncation ──────────────────────────────────────────────────────
RAW_TEXT_MAX_LENGTH=1000
